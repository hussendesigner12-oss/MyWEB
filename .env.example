# Copy this file to .env and fill values
# This project now sends consultations to Telegram only.
# Fill the Telegram bot token and numeric chat id below.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID should be the numeric chat id you get from getUpdates
TELEGRAM_CHAT_ID=987654321

# Optional: PORT the Flask app will listen on
PORT=3000